{
  "name": "majdata-hub",
  "private": true,
  "version": "0.5.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm vite:dev\" \"cargo run --manifest-path src-tauri/Cargo.toml\"",
    "bump:minor": "node scripts/bump-minor.mjs",
    "bump:fix": "node scripts/bump-fix.mjs",
    "build": "pnpm vite:build && cargo build --release --manifest-path src-tauri/Cargo.toml",
    "vite:dev": "vite",
    "vite:build": "tsc && vite build"
  },
  "dependencies": {
    "@mantine/core": "^8.3.14",
    "@mantine/hooks": "^8.3.14",
    "@mantine/notifications": "^8.3.14",
    "@tabler/icons-react": "^3.36.1",
    "framer-motion": "^12.34.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
