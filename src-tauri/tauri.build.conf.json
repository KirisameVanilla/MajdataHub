{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Majdata Hub",
  "version": "0.4.1",
  "identifier": "com.kirisamevanilla.majdata-hub",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Majdata Hub",
        "width": 1440,
        "height": 810
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2MEUwNDA1ODk2REU3Q0UKUldUTzUyMkpCUVFPRnQ5NkJiSkorNjY1eW1pL2FhOWJJL00ybkhjTGhRbmd2OXRWWmUyaDhUUXgK",
      "endpoints": [
        "https://cnb.cool/TeamMajdata/MajdataHub-Build/-/git/raw/main/latest.json?download=true",
        "https://github.com/KirisameVanilla/MajdataHub/releases/latest/download/latest.json"
      ]
    }
  }
}
